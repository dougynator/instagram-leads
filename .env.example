# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Instagram (optional - for authenticated scraping)
INSTAGRAM_SESSION_COOKIE=
# Optional: full browser cookie header for better auth reliability.
# Example: sessionid=...; csrftoken=...; ds_user_id=...; mid=...
INSTAGRAM_COOKIE_HEADER=
# Optional: newline separated list for automatic rotation.
# Each line can be a plain sessionid or a full cookie header.
INSTAGRAM_SESSION_COOKIES=
# Set to true only for demo/testing fallback data
ALLOW_MOCK_DATA=false
