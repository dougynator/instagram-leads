# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Instagram (optional - for authenticated scraping)
INSTAGRAM_SESSION_COOKIE=
# Optional: comma/newline separated list for automatic rotation
INSTAGRAM_SESSION_COOKIES=
# Set to true only for demo/testing fallback data
ALLOW_MOCK_DATA=false
